{
  "name": "@reprosight/benchmark",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "benchmark:detectors": "tsx src/run-detectors-bench.ts",
    "benchmark:localization": "tsx src/run-localization-analysis.ts",
    "e2e:mock": "tsx src/run-e2e-mock.ts",
    "evaluation:mock-matrix": "tsx src/run-mock-matrix.ts",
    "evaluation:real-provider": "tsx src/run-real-provider-eval.ts",
    "evaluation:holdout-validate": "tsx src/validate-holdout.ts",
    "evaluation:holdout-real": "tsx src/run-holdout-real-provider.ts",
    "check:report-integrity": "tsx src/check-report-integrity.ts",
    "e2e:agent": "tsx src/run-agent-e2e.ts"
  },
  "dependencies": {
    "@reprosight/core": "0.1.1",
    "execa": "^9.5.2",
    "playwright": "^1.50.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
